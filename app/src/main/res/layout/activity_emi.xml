<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMI Calculator"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etLoanAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Loan Amount (Principal)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/etInterestRate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Interest Rate (Annual %)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/etTenure"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tenure (In Months)"
        android:inputType="number" />

    <Button
        android:id="@+id/btnCalculateEMI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calculate EMI"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvEmiResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monthly EMI: 0.00"
        android:textSize="18sp"
        android:layout_marginTop="30dp"
        android:textColor="#2196F3"
        android:textStyle="bold"/>

</LinearLayout>